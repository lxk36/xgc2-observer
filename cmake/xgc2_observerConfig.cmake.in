@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Eigen3)

include("${CMAKE_CURRENT_LIST_DIR}/xgc2_observerTargets.cmake")

macro(xgc2_observer_require)
  if(NOT TARGET xgc2_observer::observer)
    message(FATAL_ERROR "xgc2_observer::observer target is not available")
  endif()
endmacro()
